<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] — Rollout TCG</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0f172a;
      color: #e2e8f0;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .card {
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 1rem;
      padding: 2rem;
      width: 100%;
      max-width: 400px;
    }
    .logo {
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .logo-mark { font-size: 1.75rem; }
    .logo-name { font-size: 1.125rem; font-weight: 700; color: #f1f5f9; margin-top: 0.25rem; }
    h1 { font-size: 1.25rem; font-weight: 600; color: #f1f5f9; margin-bottom: 1.5rem; text-align: center; }
    label { display: block; font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.375rem; }
    input[type=text], input[type=email], input[type=password] {
      width: 100%;
      padding: 0.625rem 0.875rem;
      background: #0f172a;
      border: 1px solid #334155;
      border-radius: 0.5rem;
      color: #f1f5f9;
      font-size: 0.9375rem;
      outline: none;
      transition: border-color 0.15s;
    }
    input:focus { border-color: #7c3aed; }
    .field { margin-bottom: 1rem; }
    .remember { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: #94a3b8; margin-bottom: 1.25rem; cursor: pointer; }
    .remember input { width: auto; }
    .btn {
      display: block;
      width: 100%;
      padding: 0.6875rem 1rem;
      background: #7c3aed;
      color: #fff;
      border: none;
      border-radius: 0.5rem;
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn:hover { background: #6d28d9; }
    .error {
      background: #450a0a;
      border: 1px solid #991b1b;
      color: #fca5a5;
      border-radius: 0.5rem;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      margin-bottom: 1rem;
    }
    .footer-link {
      text-align: center;
      margin-top: 1.25rem;
      font-size: 0.875rem;
      color: #64748b;
    }
    .footer-link a { color: #a78bfa; text-decoration: none; }
    .footer-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <div class="logo-mark">✦</div>
      <div class="logo-name">Rollout TCG</div>
    </div>
    @RenderBody()
  </div>
</body>
</html>
