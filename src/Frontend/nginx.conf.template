server {
    listen 80;
    root /usr/share/nginx/html;
    index index.html;

    location /api/ {
        proxy_pass http://api-gateway:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Identity Service paths — mirrors the Vite dev proxy
    location ~ ^/(\.well-known|connect|Account|grants)(/|$) {
        proxy_pass http://identity-service:5001;
        proxy_set_header Host $host;
        # FORWARDED_PROTO defaults to https (matches the TLS-terminating proxy in front of
        # this container in production); override to http for plain docker-compose dev.
        proxy_set_header X-Forwarded-Proto ${FORWARDED_PROTO};
        proxy_set_header X-Forwarded-Host $http_host;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    gzip on;
    gzip_types text/plain text/css application/javascript application/json;
}
