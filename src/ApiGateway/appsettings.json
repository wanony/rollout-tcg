{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Telemetry": {
    "OtlpEndpoint": "http://otel-collector:4317",
    "LokiEndpoint": "http://loki:3100"
  },
  "RateLimit": {
    "AnonymousPermitLimit": 60,
    "AuthenticatedPermitLimit": 300,
    "WindowSeconds": 60
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  }
}
